{
  "name": "nameplate-zone",
  "version": "1.0.0",
  "private": true,
  "description": "Nameplate Zone — Full-stack custom nameplate e-commerce (Turborepo monorepo)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "db:migrate": "npm run prisma:migrate --workspace=backend",
    "db:seed": "npm run seed --workspace=backend",
    "db:generate": "npm run prisma:generate --workspace=backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=18"
  }
}
