# Copy to .env and fill in
# Supabase: use the Session Pooler URL for serverless (Vercel) — see DEPLOYMENT.md
# URL-encode special characters in the password (! = %21, @ = %40, # = %23)
DATABASE_URL="postgresql://postgres:password@localhost:5432/nameplate_zone?schema=public"
PORT=5000
JWT_SECRET="change-me-to-a-long-random-string"
# Comma-separated list of allowed frontend origins (CORS)
CLIENT_URL="http://localhost:3000"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
